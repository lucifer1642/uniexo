{
  "name": "uniexo-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "cross-env PORT=3002 npm run start --workspace=frontend",
    "dev": "cross-env PORT=3002 npm run dev --workspace=frontend"
  },
  "dependencies": {
    "concurrently": "^9.1.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "tailwindcss": "3.4.19"
  }
}
